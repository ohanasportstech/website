<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join as Club Admin — Kai Tennis</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://ohanasports.net/invite" />
  <meta property="og:site_name" content="Kai Tennis" />
  <meta property="og:title" content="Join as Club Admin — Kai Tennis" />
  <meta property="og:description" content="You've been invited to join a tennis club as an admin on Kai Tennis. Open on your phone to accept." />
  <meta property="og:image" content="https://ohanasports.net/icons/AppIcon.png" />
  <meta property="og:image:secure_url" content="https://ohanasports.net/icons/AppIcon.png" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1024" />
  <meta property="og:image:height" content="1024" />
  <meta property="og:image:alt" content="Kai Tennis app icon" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Join as Club Admin — Kai Tennis" />
  <meta name="twitter:description" content="You've been invited to join a tennis club as an admin on Kai Tennis. Open on your phone to accept." />
  <meta name="twitter:image" content="https://ohanasports.net/icons/AppIcon.png" />

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .card {
      background: white;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      max-width: 400px;
      width: 100%;
      text-align: center;
      box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    }
    .icon {
      width: 96px;
      height: 96px;
      border-radius: 22px;
      margin-bottom: 1.5rem;
    }
    h1 { font-size: 1.5rem; font-weight: 700; color: #1d1d1f; margin-bottom: 0.75rem; }
    p  { font-size: 1rem; color: #6e6e73; line-height: 1.5; margin-bottom: 1.5rem; }
    .btn {
      display: inline-block;
      background: #0077C8;
      color: white;
      padding: 0.85rem 2rem;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      width: 100%;
    }
    .stores { margin-top: 1.5rem; color: #6e6e73; font-size: 0.875rem; }
    .stores a { color: #0077C8; text-decoration: none; margin: 0 0.4rem; }
  </style>
</head>
<body>
  <div class="card">
    <img class="icon" src="/icons/AppIcon.png" alt="Kai Tennis">
    <h1 id="heading">Accept Club Admin Invite</h1>
    <p id="body-text">You've been invited to join a tennis club as an admin. Tap below to open the Kai Tennis app and accept.</p>
    <a class="btn" id="open-btn" href="#">Open in App</a>
    <div class="stores" id="stores">
      Don't have the app?
      <a id="store-link" href="https://apps.apple.com/app/id6748925788">Download it here</a>
    </div>
  </div>

  <script>
    const ua = navigator.userAgent || "";
    const isAndroid = /android/i.test(ua);
    const isIOS = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;

    const btn = document.getElementById("open-btn");
    const storeLink = document.getElementById("store-link");

    if (isAndroid) {
      storeLink.href = "https://play.google.com/store/apps/details?id=net.OhanaSports.Kai";
    }

    if (!isIOS && !isAndroid) {
      document.getElementById("heading").textContent = "Club Admin Invite";
      document.getElementById("body-text").textContent =
        "This invite link is designed to be opened on a mobile device. Download the Kai Tennis app and then tap the link again to accept.";
      btn.style.display = "none";
      document.getElementById("stores").innerHTML =
        'Download the app: ' +
        '<a href="https://apps.apple.com/app/id6748925788" style="color:#0077C8;text-decoration:none;">App Store</a>' +
        ' &nbsp;|&nbsp; ' +
        '<a href="https://play.google.com/store/apps/details?id=net.OhanaSports.Kai" style="color:#0077C8;text-decoration:none;">Google Play</a>';
    } else {
      btn.href = window.location.href;
    }
  </script>
</body>
</html>
